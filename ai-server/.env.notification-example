# ============================================================================
# Email Notification Configuration - Priority-Based Fallback Example
# ============================================================================
# This example shows how to configure multiple email providers with explicit
# priority numbers for automatic failover.
#
# PRIORITY SYSTEM:
# - Lower number = Higher priority (tried first)
# - Priority 1 = Primary provider
# - Priority 50 = Secondary/fallback provider
# - Priority 99 = Last resort provider
# ============================================================================

# ----------------------------------------------------------------------------
# Provider List
# ----------------------------------------------------------------------------
# List all providers you want to use (comma-separated)
# Order doesn't matter when using explicit priorities
EMAIL_PROVIDERS=sendgrid,mailgun,smtp

# ----------------------------------------------------------------------------
# Fallback Strategy
# ----------------------------------------------------------------------------
# fallback   = Try providers in priority order until one succeeds (RECOMMENDED)
# roundrobin = Distribute load evenly across all providers
# no-fallback = Only use first provider
EMAIL_MULTI_PROVIDER_STRATEGY=fallback

# ----------------------------------------------------------------------------
# SendGrid Configuration (Primary Provider)
# ----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_PRIORITY=1    # Highest priority - tried first

# ----------------------------------------------------------------------------
# Mailgun Configuration (Secondary/Fallback Provider)
# ----------------------------------------------------------------------------
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_PRIORITY=50    # Medium priority - tried if SendGrid fails

# ----------------------------------------------------------------------------
# SMTP Configuration (Last Resort Provider)
# ----------------------------------------------------------------------------
# Use any SMTP server: Gmail, Office365, or custom
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_SECURE=false
SMTP_PRIORITY=99       # Lowest priority - tried if all others fail

# ----------------------------------------------------------------------------
# Sender Configuration (Shared Across All Providers)
# ----------------------------------------------------------------------------
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=JIRAForge

# ----------------------------------------------------------------------------
# Optional: Notification Polling Settings
# ----------------------------------------------------------------------------
NOTIFICATION_POLLING_INTERVAL=900000        # 15 minutes (in milliseconds)
INACTIVITY_THRESHOLD_HOURS=3.5              # Hours before sending inactivity alert
LOGIN_REMINDER_DAYS=7                       # Days since last login to trigger reminder

# ============================================================================
# PRIORITY EXAMPLES
# ============================================================================
#
# EXAMPLE 1: Two-tier fallback (Primary + Backup)
# -------------------------------------------------
# EMAIL_PROVIDERS=sendgrid,smtp
# SENDGRID_PRIORITY=1
# SMTP_PRIORITY=99
#
# EXAMPLE 2: Three-tier fallback (Premium → Backup → Free)
# ---------------------------------------------------------
# EMAIL_PROVIDERS=sendgrid,mailgun,smtp
# SENDGRID_PRIORITY=1
# MAILGUN_PRIORITY=50
# SMTP_PRIORITY=99
#
# EXAMPLE 3: Load balancing (Equal priorities)
# ----------------------------------------------
# EMAIL_PROVIDERS=sendgrid,mailgun,ses
# EMAIL_MULTI_PROVIDER_STRATEGY=roundrobin
# SENDGRID_PRIORITY=10
# MAILGUN_PRIORITY=10
# SES_PRIORITY=10
#
# EXAMPLE 4: No explicit priorities (uses array order)
# -----------------------------------------------------
# EMAIL_PROVIDERS=sendgrid,mailgun,smtp
# # No PRIORITY vars = sendgrid first, mailgun second, smtp third
#
