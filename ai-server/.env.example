# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# API Security
AI_SERVER_API_KEY=your_secure_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================

# Primary AI Provider: LiteLLM (set to 'true' to enable)
# When enabled, LiteLLM is used as primary with OpenAI as fallback
USE_LITELLM=false

# LiteLLM Configuration (only needed if USE_LITELLM=true)
LITELLM_API_KEY=sk-your-litellm-virtual-key
LITELLM_BASE_URL=https://litellm.amzur.com
LITELLM_MODEL=fireworks_ai/accounts/fireworks/models/llama-v3p2-90b-vision-instruct
LITELLM_USER=your.email@amzur.com

# LiteLLM Fallback Settings
LITELLM_FAILURE_THRESHOLD=3        # Switch to OpenAI after this many consecutive failures
LITELLM_COOLDOWN_MINUTES=5         # Wait this long before trying LiteLLM again

# OpenAI Configuration (fallback when LiteLLM fails, or primary if USE_LITELLM=false)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VISION_MODEL=gpt-4o         # For screenshot analysis
OPENAI_MODEL=gpt-4o-mini           # For text tasks (OCR, clustering)

# Or use Google Gemini instead (not currently integrated with LiteLLM fallback)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-pro

# Screenshot Analysis Configuration
SCREENSHOT_INTERVAL=300
AUTO_CREATE_WORKLOGS=false

# Polling Configuration (backup for webhook-based processing)
POLLING_INTERVAL_MS=180000  # 3 minutes - webhook handles real-time, polling is backup

# BRD Processing Configuration
AUTO_CREATE_JIRA_ISSUES=false

# Forge App Integration (for creating worklogs and issues)
FORGE_APP_URL=https://your-forge-app-url
FORGE_API_KEY=your_forge_api_key

# Optional: Google Cloud Vision API (alternative to Tesseract for better OCR)
# GOOGLE_VISION_API_KEY=your_google_vision_api_key
