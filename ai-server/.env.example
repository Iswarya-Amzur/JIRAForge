# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# API Security
AI_SERVER_API_KEY=your_secure_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# =============================================================================
# ATLASSIAN OAUTH CONFIGURATION (for Desktop App Authentication)
# =============================================================================
# These secrets are now on the server only - removed from desktop app for security
ATLASSIAN_CLIENT_ID=your_atlassian_client_id
ATLASSIAN_CLIENT_SECRET=your_atlassian_client_secret

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================
# Provider Priority: Fireworks -> LiteLLM
# Enable the providers you want to use. First enabled provider is primary.

# -----------------------------------------------------------------------------
# Fireworks AI (Primary - Recommended for vision tasks)
# -----------------------------------------------------------------------------
USE_FIREWORKS=flase
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/qwen2p5-vl-32b-instruct

# -----------------------------------------------------------------------------
# LiteLLM (Fallback - for proxy-based routing)
# -----------------------------------------------------------------------------
USE_LITELLM=true
LITELLM_API_KEY=sk-your-litellm-virtual-key
# NOTE: Use internal IP within E2E Cloud VPC (public IP traffic is blocked)
# External: https://litellm.amzur.com (won't work inside VPC)
# Internal: http://10.15.226.9:4000 (use this on E2E Cloud servers)
LITELLM_BASE_URL=http://10.15.226.9:4000
LITELLM_MODEL=gpt-4o
LITELLM_USER=your.email@amzur.com

# -----------------------------------------------------------------------------
# Fallback Settings
# -----------------------------------------------------------------------------
FAILURE_THRESHOLD=3              # Switch to fallback after this many consecutive failures
COOLDOWN_MINUTES=5               # Wait this long before trying primary again

# =============================================================================
# AI FEATURE FLAGS
# =============================================================================
# Use AI for screenshot analysis (set to 'false' to disable AI and use only heuristics)
USE_AI_FOR_SCREENSHOTS=true

# Use OCR fallback when Vision analysis fails (set to 'false' to skip OCR and use basic heuristics)
USE_OCR_FALLBACK=true

# Screenshot Analysis Configuration
SCREENSHOT_INTERVAL=300
AUTO_CREATE_WORKLOGS=false

# Polling Configuration (backup for webhook-based processing)
POLLING_INTERVAL_MS=180000  # 3 minutes - webhook handles real-time, polling is backup

# =============================================================================
# CLEANUP SERVICE CONFIGURATION (Old Screenshot Deletion)
# =============================================================================
# Deletes old screenshot files from storage to save space
# Database records are preserved for time tracking history

# Day of month to run cleanup (default: 1 = 1st of each month)
CLEANUP_SCHEDULE_DAY=1

# Hour to run cleanup in 24-hour format (default: 3 = 3 AM)
CLEANUP_SCHEDULE_HOUR=3

# Minute to run cleanup (default: 0)
CLEANUP_SCHEDULE_MINUTE=0

# Number of months to keep (default: 2 = delete files older than 2 months)
CLEANUP_MONTHS_TO_KEEP=2

# Batch size for processing (default: 50 screenshots per batch)
CLEANUP_BATCH_SIZE=50

# BRD Processing Configuration
AUTO_CREATE_JIRA_ISSUES=false

# Forge App Integration (for creating worklogs and issues)
FORGE_APP_URL=https://your-forge-app-url
FORGE_API_KEY=your_forge_api_key

# Optional: Google Cloud Vision API (alternative to Tesseract for better OCR)
# GOOGLE_VISION_API_KEY=your_google_vision_api_key

# =============================================================================
# GOOGLE SHEETS LOGGING (LLM Usage Tracking)
# =============================================================================
# Enable/disable logging to Google Sheets
SHEETS_LOGGING_ENABLED=true

# Google Sheet ID (from URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/...)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Sheet tab name (default: LLM_Calls_Log)
GOOGLE_SHEET_NAME=LLM_Calls_Log

# Google Service Account JSON (escaped or single-line JSON)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant "Editor" access to the spreadsheet for the service account email
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Metadata for logging
SHEETS_PROJECT_NAME=Jira AI Server
SHEETS_EMPLOYEE_NAME=AI Server
SHEETS_API_ACCOUNT_EMAIL=ai-server@amzur.com
