# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# API Security
AI_SERVER_API_KEY=your_secure_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI Configuration (for BRD processing)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Or use Google Gemini instead
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-pro

# Screenshot Analysis Configuration
SCREENSHOT_INTERVAL=300
AUTO_CREATE_WORKLOGS=false

# BRD Processing Configuration
AUTO_CREATE_JIRA_ISSUES=false

# Forge App Integration (for creating worklogs and issues)
FORGE_APP_URL=https://your-forge-app-url
FORGE_API_KEY=your_forge_api_key

# Optional: Google Cloud Vision API (alternative to Tesseract for better OCR)
# GOOGLE_VISION_API_KEY=your_google_vision_api_key
