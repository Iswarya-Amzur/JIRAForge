# =============================================================================
# DESKTOP APP CONFIGURATION
# =============================================================================
# SECURITY NOTE: All sensitive secrets have been removed from the desktop app
# and moved to the AI Server for security. Credentials are fetched at runtime
# after the user authenticates with Atlassian.
# =============================================================================

# Atlassian OAuth Configuration
# Only CLIENT_ID is needed here - CLIENT_SECRET is on AI Server
ATLASSIAN_CLIENT_ID=your_client_id_here

# AI Server Configuration (handles secure token exchange & provides Supabase config)
AI_SERVER_URL=http://your-ai-server-url:3001

# Application Configuration
CAPTURE_INTERVAL=300
WEB_PORT=51777
ADMIN_PASSWORD=admin123

# =============================================================================
# REMOVED SECRETS (now fetched from AI Server after authentication)
# =============================================================================
# ATLASSIAN_CLIENT_SECRET - on AI Server only
# SUPABASE_URL - fetched from AI Server
# SUPABASE_ANON_KEY - fetched from AI Server
# SUPABASE_SERVICE_ROLE_KEY - fetched from AI Server
# =============================================================================
#
# HOW IT WORKS:
# 1. User logs in with Atlassian OAuth
# 2. Desktop app exchanges OAuth code via AI Server (server has CLIENT_SECRET)
# 3. Desktop app requests Supabase config from AI Server (requires valid token)
# 4. AI Server verifies Atlassian token and returns Supabase credentials
# 5. Desktop app initializes Supabase clients with fetched credentials
# =============================================================================

# =============================================================================
# OCR TESTING CONFIGURATION (Optional - Only for testing)
# =============================================================================
# These variables are only needed for running OCR test scripts
# (test_ocr_quick.py, test_ocr_verbose.py)
# Do NOT use these in production - production uses AI Server config
# =============================================================================

# Supabase Configuration (for testing only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Test User IDs (for OCR testing)
TEST_USER_ID=00000000-0000-0000-0000-000000000001
TEST_ORG_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# OCR ENGINE CONFIGURATION
# =============================================================================
# The system supports multiple OCR engines with automatic fallback.
# Engines can be configured dynamically - just specify the engine name and
# the system will automatically create an adapter for it!
# =============================================================================

# Primary OCR Engine (first choice)
# Built-in engines: paddle, tesseract, easyocr, mock, demo
# Or configure any OCR library dynamically (see below)
OCR_PRIMARY_ENGINE=paddle

# Fallback Engines (comma-separated, tried in order if primary fails)
OCR_FALLBACK_ENGINES=tesseract,mock

# Engine-specific settings (pattern: OCR_<ENGINE>_<SETTING>)
OCR_PADDLE_MIN_CONFIDENCE=0.5
OCR_PADDLE_USE_GPU=false
OCR_PADDLE_LANGUAGE=en

OCR_TESSERACT_MIN_CONFIDENCE=0.6
OCR_TESSERACT_LANGUAGE=eng

OCR_EASYOCR_MIN_CONFIDENCE=0.7
OCR_EASYOCR_LANGUAGES=en
OCR_EASYOCR_GPU=false

# =============================================================================
# DYNAMIC ENGINE CONFIGURATION
# =============================================================================
# You can use ANY OCR library without creating engine adapter files!
# Just configure the engine name - the system will try to auto-detect the package.
#
# Example 1: Auto-detection (if package name matches engine name)
# OCR_PRIMARY_ENGINE=surya
# # System tries: surya, suryaocr, pysurya, etc. (auto-detected!)
#
# Example 2: Explicit package (when auto-detection might fail)
# OCR_PRIMARY_ENGINE=suryaocr
# OCR_SURYAOCR_PACKAGE=surya              # Explicit package name
# OCR_SURYAOCR_MIN_CONFIDENCE=0.7
# OCR_SURYAOCR_USE_GPU=true
#
# Example 3: Using TrOCR (Hugging Face)
# OCR_PRIMARY_ENGINE=trocr
# OCR_TROCR_PACKAGE=transformers          # Auto-detected if transformers installed
# OCR_TROCR_CLASS=TrOCRProcessor          # Optional: specific class name
# OCR_TROCR_METHOD=decode                 # Optional: specific method name
# OCR_TROCR_MODEL=microsoft/trocr-base    # Custom parameter
#
# Smart Auto-Detection tries:
# - Engine name as-is: 'surya' → import surya
# - Known mappings: 'suryaocr' → import surya
# - Common patterns: 'paddle' → import paddleocr
# 
# Known mappings (no package config needed):
# - paddle, paddleocr → paddleocr
# - tesseract → pytesseract
# - easyocr → easyocr
# - suryaocr, surya → surya
# - doctr → python-doctr
# - trocr → transformers
# - kerasocr → keras_ocr
# =============================================================================

# =============================================================================
# LOG SANITIZATION (PII Protection)
# =============================================================================
# Automatically redacts sensitive information from log output.
# Protects: emails, UUIDs, account IDs, IPs, JWT tokens, API keys
# Use secure_logger.py for PII-safe logging in Python code.

# Enable/disable log sanitization (default: true)
SECURE_LOG_ENABLED=true

# Sanitization level:
# - minimal: Only PII (emails, credit cards, phone numbers, JWT tokens, API keys)
# - standard: PII + UUIDs + Atlassian IDs + IP addresses (recommended)
# - strict: All patterns including infrastructure IDs
SECURE_LOG_LEVEL=standard

# Include timestamps in log output (default: false)
LOG_TIMESTAMPS=false
# =============================================================================
