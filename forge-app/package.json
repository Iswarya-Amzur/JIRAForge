{
  "name": "brd-automate-time-tracker",
  "version": "1.0.0",
  "description": "BRD Automation & Time Tracker for Jira",
  "main": "src/index.js",
  "scripts": {
    "build": "npm run build:main && npm run build:settings",
    "build:main": "cd static/main && npm run build",
    "build:settings": "cd static/settings && npm run build",
    "deploy": "forge deploy",
    "install-app": "forge install",
    "tunnel": "forge tunnel",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "jira",
    "forge",
    "time-tracking",
    "brd",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@forge/api": "^3.0.0",
    "@forge/resolver": "^1.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@forge/cli": "^12.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react-scripts": "^5.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageReporters": [
      "lcov",
      "text"
    ]
  }
}
