{
  "name": "brd-time-tracker-desktop",
  "version": "1.0.0",
  "description": "Desktop app for BRD Automate & Time Tracker - captures screenshots and tracks time",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "jira",
    "time-tracking",
    "screenshot",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "active-win": "^7.7.2",
    "axios": "^1.6.0",
    "dotenv": "^17.2.3",
    "electron-store": "^8.1.0",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.brdtimetracker.app",
    "productName": "BRD Time Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "BRD Time Tracker OAuth",
        "schemes": [
          "brd-time-tracker"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
