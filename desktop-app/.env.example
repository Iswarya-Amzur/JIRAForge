# Atlassian OAuth Configuration
# Get these from https://developer.atlassian.com/console/myapps/
ATLASSIAN_CLIENT_ID=your_client_id_here
ATLASSIAN_CLIENT_SECRET=your_client_secret_here

# Supabase Authentication Endpoint
# This should point to your Supabase Edge Function that handles Atlassian auth
SUPABASE_AUTH_URL=https://your-project.supabase.co/functions/v1
